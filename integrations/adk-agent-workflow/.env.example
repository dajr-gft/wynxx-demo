# ADK SDLC workflow configuration. Copy to `.env`. Defaults run offline.

# --- App configuration -------------------------------------------------------
# stub = deterministic offline agents (default); real = ADK agents + Wynxx MCP
SDLC_MODE=stub

# Wynxx MCP server endpoint (used when SDLC_MODE=real).
SDLC_MCP_URL=https://wynxx-mcp-server-xxxxx.run.app/mcp

# Models per role (article: Pro for reasoning, Flash for volume).
SDLC_MODEL_PRO=gemini-3-pro
SDLC_MODEL_FLASH=gemini-3-flash

# --- Vertex AI / ADK (required for SDLC_MODE=real and deployment) ------------
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=my-project
GOOGLE_CLOUD_LOCATION=us-central1
# Staging bucket for `deployment/deploy.py` (name only, no gs:// prefix).
GOOGLE_CLOUD_STORAGE_BUCKET=my-staging-bucket
