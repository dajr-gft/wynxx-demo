# Wynxx MCP server — environment configuration.
# Copy to `.env` and adjust. All variables are optional; defaults run offline.

# --- Backend selection -------------------------------------------------------
# stub = deterministic, offline reference responses (default)
# real = call a live Wynxx backend over HTTP
WYNXX_MODE=stub

# Live backend endpoint (used only when WYNXX_MODE=real).
# Example: the instance wired into ../../.gemini/settings.json
# WYNXX_BACKEND_URL=https://34.71.69.43.nip.io
# WYNXX_BACKEND_TOKEN=
# WYNXX_BACKEND_TIMEOUT_SECONDS=60

# --- MCP server identity -----------------------------------------------------
WYNXX_SERVER_NAME=wynxx
WYNXX_MCP_SERVER_ID=wynxx-sdlc

# --- Network (Cloud Run injects PORT) ----------------------------------------
WYNXX_HOST=0.0.0.0
# PORT=8080

# --- Observability -----------------------------------------------------------
WYNXX_LOG_LEVEL=INFO
WYNXX_ENABLE_OTEL=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317